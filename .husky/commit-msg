#!/usr/bin/env sh
set -eu

message_file="$1"
subject="$(sed -n '1p' "$message_file")"

case "$subject" in
  ci:*|cli:*|package:*|plugin:*|app:*|lua:*|tauri:*|feather:*|shadergraph:*|docs:*|vscode-extension:*|particles:*|mcp:*)
    exit 0
    ;;
esac

cat <<'EOF'
[feather] Invalid commit message.

Commit message must start with one of:
  ci:
  cli:
  package:
  plugin:
  app:
  lua:
  tauri:
  feather:
  shadergraph:
  particles:
  docs:
  mcp:
  vscode-extension:

Examples:
  ci: update repo workflows
  cli: add interactive plugin workflow
  app: improve assets panel
  lua: add debugger binary payloads
  tauri: update file permissions
  feather: update repo structure
  shadergraph: updates to the shader graph
  particles: Particles system
  docs: add contribution guidelines
  vscode-extension: update extension manifest
  mcp: add any mcp related changes
EOF

exit 1
