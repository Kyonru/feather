{
  "name": "@kyonru/feather",
  "version": "0.9.3",
  "description": "CLI for Feather — run and debug Love2D games without touching your game code",
  "license": "EPL-2.0",
  "keywords": [
    "feather",
    "love2d",
    "cli",
    "debugger",
    "devtool",
    "inspector",
    "lua"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kyonru/feather.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/Kyonru/feather/issues"
  },
  "homepage": "https://kyonru.github.io/feather",
  "type": "module",
  "bin": {
    "feather": "./dist/index.js"
  },
  "files": [
    "dist",
    "lua"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "bundle:lua": "bash ../scripts/bundle-lua.sh",
    "prepack": "npm run bundle:lua && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ink": "^7.0.2",
    "ora": "^8.0.1",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^24.2.0",
    "typescript": "~5.6.2"
  },
  "engines": {
    "node": ">=18"
  }
}
