{
  "name": "feather",
  "description": "Feather is a Love2D devtool to debug and inspect your game in real-time. It provides a web-based interface to view and manipulate game state, visualize physics, and more.",
  "private": true,
  "version": "0.10.0",
  "type": "module",
  "workspaces": [
    "cli"
  ],
  "scripts": {
    "cli:build": "npm run build --workspace=cli",
    "cli:dev": "npm run dev --workspace=cli",
    "test:cli:e2e": "npm run cli:build && node cli/test/e2e.mjs && node cli/test/package.test.mjs",
    "test:lua:e2e": "node scripts/lua-e2e.mjs",
    "test:app:e2e": "playwright test",
    "test:tauri:e2e": "cargo test --manifest-path src-tauri/Cargo.toml ws_server",
    "feather": "node cli/dist/index.js",
    "dev": "vite",
    "dev:lua": "concurrently \"vite\" \"sh ./scripts/watch-lua.sh\"",
    "web": "vite",
    "docs": "docker run --rm -it -p 8000:8000 -v \"$(pwd):/docs\" -w /docs --entrypoint sh squidfunk/mkdocs-material -c \"pip install -r requirements-docs.txt && mkdocs serve --dev-addr=0.0.0.0:8000\"",
    "native": "npm run tauri build -- --debug",
    "lua": "sh ./scripts/watch-lua.sh",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck:web": "tsc --noEmit -p tsconfig.json --composite false",
    "typecheck:lua": "luacheck src-lua",
    "typecheck": "npm run typecheck:web && npm run typecheck:lua",
    "generate:plugin-catalog": "node scripts/generate-plugin-catalog.mjs",
    "check:plugin-catalog": "npm run generate:plugin-catalog && git diff --exit-code cli/src/generated/plugin-catalog.ts",
    "generate:registry": "node scripts/generate-registry.mjs",
    "check:registry": "npm run generate:registry && git diff --exit-code cli/src/generated/registry.json",
    "verify:packages": "node scripts/compute-checksums.mjs --all",
    "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "tauri": "tauri",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "1.4.1",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/modifiers": "9.0.0",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toggle": "1.1.10",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/query-async-storage-persister": "5.100.10",
    "@tanstack/react-query": "5.100.10",
    "@tanstack/react-query-persist-client": "5.100.10",
    "@tanstack/react-table": "8.21.3",
    "@tauri-apps/api": "2",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-fs": "2.5.1",
    "@tauri-apps/plugin-opener": "2.5.4",
    "@tauri-apps/plugin-shell": "2.3.5",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "gif.js": "0.2.0",
    "gif.js.optimized": "1.0.1",
    "lucide-react": "1.16.0",
    "next-themes": "0.4.6",
    "prism-react-renderer": "2.4.1",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-resizable-panels": "4.11.1",
    "react-router": "7.15.1",
    "react-syntax-highlighter": "16.1.1",
    "react-virtuoso": "4.18.7",
    "recharts": "3.8.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "vaul": "1.1.2",
    "zod": "4.4.3",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@tanstack/eslint-plugin-query": "5.100.10",
    "@tauri-apps/cli": "2",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "9.2.1",
    "eslint": "10.3.0",
    "husky": "9.1.7",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.13"
  }
}
